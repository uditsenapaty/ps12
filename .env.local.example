# Copy to .env.local (gitignored) and fill the ones you need. NEVER commit .env.local.
# connect.py / data_setup.py read these from the environment — nothing is hardcoded.

# --- data: INSAT via MOSDAC (required to download INSAT) ---
MOSDAC_USERNAME=
MOSDAC_PASSWORD=

# --- model weights / optional report narrative ---
HF_TOKEN=
OPENAI_API_KEY=            # optional, <$10, only for the report narrative

# --- cloud compute: Lightning.ai (Settings -> Keys -> Programmatic Login) ---
LIGHTNING_USER_ID=
LIGHTNING_API_KEY=
LIGHTNING_TEAMSPACE=       # e.g. "myname/vision"  (teamspace path; optional)
LIGHTNING_STUDIO=ps12      # studio name to create/reuse

# --- cloud compute: Kaggle (Account -> API -> Create New Token = kaggle.json) ---
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- serve the dashboard from the remote to your local browser (free token: dashboard.ngrok.com) ---
NGROK_AUTHTOKEN=

# --- code source used by remote runners (git clone target); optional ---
REPO_URL=                  # e.g. https://github.com/<you>/ps12.git
